<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="450.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.view.PagamentoController">

    <children>

        <!-- Título -->
        <Label text="Pagamento"
               layoutX="0" layoutY="0"
               prefWidth="450"
               alignment="CENTER"
               style="-fx-background-color: #2c3e50; -fx-text-fill: white;">
            <font>
                <Font size="18"/>
            </font>
        </Label>

        <!-- Total -->
        <Label text="Total:"
               layoutX="30" layoutY="60"/>

        <Label fx:id="lblTotal"
               layoutX="100" layoutY="60"
               text="R$ 0,00"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <!-- Forma de pagamento -->
        <Label text="Forma de pagamento:"
               layoutX="30" layoutY="100"/>

        <ComboBox fx:id="cbPagamento"
                  layoutX="30" layoutY="130"
                  prefWidth="200"/>

        <!-- Valor pago -->
        <Label text="Valor:"
               layoutX="250" layoutY="100"/>

        <TextField fx:id="txtValorPago"
                   layoutX="250" layoutY="130"
                   prefWidth="120"/>

        <!-- Botão adicionar -->
        <Button text="Adicionar"
                layoutX="150" layoutY="170"
                onAction="#adicionarPagamento"/>

        <!-- Tabela de pagamentos -->
        <TableView fx:id="tvPagamentos"
                   layoutX="30" layoutY="210"
                   prefWidth="380"
                   prefHeight="120">

            <columns>
                <TableColumn fx:id="colTipo"
                             text="Tipo"
                             prefWidth="180"/>
                <TableColumn fx:id="colValor"
                             text="Valor"
                             prefWidth="180"/>
            </columns>

        </TableView>

        <!-- Troco -->
        <Label fx:id="lblTroco"
               layoutX="30" layoutY="340"
               text="Troco: R$ 0,00"
               style="-fx-font-weight: bold;"/>

        <!-- Botões -->
        <Button text="Confirmar"
                layoutX="80" layoutY="380"
                onAction="#Confirmar"/>

        <Button text="Cancelar"
                layoutX="250" layoutY="380"
                onAction="#Cancelar"/>

    </children>
</AnchorPane>